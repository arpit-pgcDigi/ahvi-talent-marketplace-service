{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api-gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "tsconfig.build.json"
  },
  "monorepo": true,
  "root": "apps/api-gateway",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": { "tsConfigPath": "apps/api-gateway/tsconfig.app.json" }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": { "tsConfigPath": "apps/auth-service/tsconfig.app.json" }
    },
    "talent-service": {
      "type": "application",
      "root": "apps/talent-service",
      "entryFile": "main",
      "sourceRoot": "apps/talent-service/src",
      "compilerOptions": { "tsConfigPath": "apps/talent-service/tsconfig.app.json" }
    },
    "marketplace-service": {
      "type": "application",
      "root": "apps/marketplace-service",
      "entryFile": "main",
      "sourceRoot": "apps/marketplace-service/src",
      "compilerOptions": { "tsConfigPath": "apps/marketplace-service/tsconfig.app.json" }
    },
    "orders-service": {
      "type": "application",
      "root": "apps/orders-service",
      "entryFile": "main",
      "sourceRoot": "apps/orders-service/src",
      "compilerOptions": { "tsConfigPath": "apps/orders-service/tsconfig.app.json" }
    },
    "engagement-service": {
      "type": "application",
      "root": "apps/engagement-service",
      "entryFile": "main",
      "sourceRoot": "apps/engagement-service/src",
      "compilerOptions": { "tsConfigPath": "apps/engagement-service/tsconfig.app.json" }
    },
    "admin-service": {
      "type": "application",
      "root": "apps/admin-service",
      "entryFile": "main",
      "sourceRoot": "apps/admin-service/src",
      "compilerOptions": { "tsConfigPath": "apps/admin-service/tsconfig.app.json" }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": { "tsConfigPath": "apps/notification-service/tsconfig.app.json" }
    },
    "prisma": {
      "type": "library",
      "root": "libs/prisma",
      "entryFile": "index",
      "sourceRoot": "libs/prisma/src",
      "compilerOptions": { "tsConfigPath": "libs/prisma/tsconfig.lib.json" }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": { "tsConfigPath": "libs/contracts/tsconfig.lib.json" }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": { "tsConfigPath": "libs/common/tsconfig.lib.json" }
    }
  }
}